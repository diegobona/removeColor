---
import { detailExampleScenarios } from '../data/exampleScenarios';
import ScenarioSubject from './ScenarioSubject.astro';
---

{
  detailExampleScenarios.length > 0 && (
    <section class="section examples-section" aria-labelledby="examples-heading">
      <div class="section__inner">
        <div class="section-heading">
          <p class="eyebrow">More examples</p>
          <h2 id="examples-heading">Common color-removal results</h2>
          <p>A few more examples of selected colors becoming transparent.</p>
        </div>

        <div class="comparison-grid comparison-grid--real">
          {detailExampleScenarios.map((scenario) => (
            <article class="comparison-card">
              <div class="comparison-card__header">
                <strong>{scenario.title}</strong>
                <span>{scenario.removeLabel}</span>
              </div>
              {
                scenario.media ? (
                  <figure class="real-example">
                    <img src={scenario.media.beforeSrc} alt={scenario.media.alt} loading="lazy" />
                    <figcaption>
                      <span>{scenario.before.label}</span>
                      {scenario.targetColor && <code>{scenario.targetColor}</code>}
                    </figcaption>
                  </figure>
                ) : (
                  <div class="comparison-card__pair">
                    <figure class="mock-image" style={`--mock-bg: ${scenario.before.background};`}>
                      <div class="mock-image__surface mock-image__surface--solid">
                        <ScenarioSubject scenario={scenario} />
                      </div>
                      <figcaption>{scenario.before.label}</figcaption>
                    </figure>
                    <figure class="mock-image">
                      <div class="mock-image__surface mock-image__surface--transparent">
                        <ScenarioSubject scenario={scenario} />
                      </div>
                      <figcaption>{scenario.after.label}</figcaption>
                    </figure>
                  </div>
                )
              }
            </article>
          ))}
        </div>
      </div>
    </section>
  )
}
