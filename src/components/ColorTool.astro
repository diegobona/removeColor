---
import { cleanupPresets, getDefaultCleanupPreset } from '../lib/controlPresets';

const defaultPreset = getDefaultCleanupPreset();
---

<section class="tool" aria-label="Remove color from image tool">
  <input id="fileInput" class="tool__file-input" type="file" accept="image/png,image/jpeg,image/webp" />

  <div class="tool__workspace" id="workspace" data-active="false">
    <div class="compare-stage compare-stage--checker" id="compareStage">
      <div class="compare-grid">
        <section class="compare-panel">
          <div class="compare-panel__header">
            <strong>Input image</strong>
            <span class="compare-panel__hint">Click on a color</span>
          </div>
          <div class="compare-panel__surface" id="beforeSurface">
            <div class="before-empty" id="beforeEmpty">
              <label class="before-empty__button" for="fileInput">
                <span class="before-empty__plus" aria-hidden="true">+</span>
                <span>Click to load an image</span>
              </label>
              <div class="before-empty__notes">
                <span>Or drop an image here</span>
                <span>Or paste it here (Ctrl+V)</span>
                <span>Or load from examples above</span>
              </div>
            </div>
            <canvas id="beforeCanvas" width="960" height="540"></canvas>
          </div>
          <div class="compare-panel__actions compare-panel__actions--placeholder" aria-hidden="true">
            <button class="button button--primary compare-panel__download" type="button" tabindex="-1">Download PNG</button>
          </div>
        </section>

        <section class="compare-panel">
          <div class="compare-panel__header">
            <strong>Output image</strong>
          </div>
          <div class="compare-panel__surface" id="afterSurface">
            <canvas id="afterCanvas" width="960" height="540"></canvas>
          </div>
          <div class="compare-panel__actions">
            <button class="button button--primary compare-panel__download" id="downloadButton" type="button" disabled>
              Download PNG
            </button>
          </div>
        </section>
      </div>
    </div>

    <div class="controls" aria-label="Color removal controls">
      <div class="control-row control-row--split">
        <label>
          <span>Target color</span>
          <input id="targetHex" type="text" value="#ffffff" inputmode="text" autocomplete="off" />
        </label>
        <label>
          <span>Picker</span>
          <input id="targetColor" type="color" value="#ffffff" />
        </label>
      </div>

      <div class="control-group">
        <span>Cleanup preset</span>
        <div class="preset-grid" role="group" aria-label="Cleanup preset">
          {
            cleanupPresets.map((preset) => (
              <button
                type="button"
                data-preset={preset.id}
                data-tolerance={preset.values.tolerance}
                data-softness={preset.values.edgeSoftness}
                data-halo={preset.values.haloCleanup}
                aria-pressed={preset.id === defaultPreset.id}
              >
                <strong>{preset.label}</strong>
                <small>{preset.helper}</small>
              </button>
            ))
          }
        </div>
      </div>

      <details class="advanced-controls">
        <summary>Fine-tune result</summary>
        <label class="range-row">
          <span>
            Color range
            <small>Higher removes more similar shades.</small>
          </span>
          <input id="toleranceInput" type="range" min="0" max="100" value={defaultPreset.values.tolerance} />
          <output id="toleranceOutput">{defaultPreset.values.tolerance}</output>
        </label>

        <label class="range-row">
          <span>
            Smooth edge
            <small>Higher softens jagged pixels.</small>
          </span>
          <input id="softnessInput" type="range" min="0" max="100" value={defaultPreset.values.edgeSoftness} />
          <output id="softnessOutput">{defaultPreset.values.edgeSoftness}</output>
        </label>

        <label class="range-row">
          <span>
            Remove edge tint
            <small>Higher reduces white or color outlines.</small>
          </span>
          <input id="haloInput" type="range" min="0" max="100" value={defaultPreset.values.haloCleanup} />
          <output id="haloOutput">{defaultPreset.values.haloCleanup}</output>
        </label>
      </details>

      <div class="control-group">
        <span>Preview background</span>
        <div class="segmented" role="group" aria-label="Preview background">
          <button type="button" data-bg="checker" aria-pressed="true">Grid</button>
          <button type="button" data-bg="white" aria-pressed="false">White</button>
          <button type="button" data-bg="black" aria-pressed="false">Black</button>
          <label>
            <input id="customBg" type="color" value="#33a6ff" />
            Custom
          </label>
        </div>
      </div>

      <div class="tool__footer">
        <p id="statusText" role="status">Choose an image to start.</p>
        <div class="tool__footer-actions">
          <button class="button button--ghost" id="resetButton" type="button" disabled>Reset</button>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { parseHexColor, removeColorFromPixels, rgbToHex } from '../lib/colorRemoval';
  import { getContainedPreviewSize } from '../lib/previewSizing';

  type ExampleLoadDetail = {
    source: string;
    name: string;
  };

  const fileInput = document.querySelector<HTMLInputElement>('#fileInput');
  const workspace = document.querySelector<HTMLElement>('#workspace');
  const compareStage = document.querySelector<HTMLElement>('#compareStage');
  const beforeSurface = document.querySelector<HTMLElement>('#beforeSurface');
  const afterSurface = document.querySelector<HTMLElement>('#afterSurface');
  const beforeCanvas = document.querySelector<HTMLCanvasElement>('#beforeCanvas');
  const afterCanvas = document.querySelector<HTMLCanvasElement>('#afterCanvas');
  const beforeEmpty = document.querySelector<HTMLElement>('#beforeEmpty');
  const targetHex = document.querySelector<HTMLInputElement>('#targetHex');
  const targetColor = document.querySelector<HTMLInputElement>('#targetColor');
  const toleranceInput = document.querySelector<HTMLInputElement>('#toleranceInput');
  const softnessInput = document.querySelector<HTMLInputElement>('#softnessInput');
  const haloInput = document.querySelector<HTMLInputElement>('#haloInput');
  const toleranceOutput = document.querySelector<HTMLOutputElement>('#toleranceOutput');
  const softnessOutput = document.querySelector<HTMLOutputElement>('#softnessOutput');
  const haloOutput = document.querySelector<HTMLOutputElement>('#haloOutput');
  const presetButtons = document.querySelectorAll<HTMLButtonElement>('[data-preset]');
  const customBg = document.querySelector<HTMLInputElement>('#customBg');
  const statusText = document.querySelector<HTMLElement>('#statusText');
  const resetButton = document.querySelector<HTMLButtonElement>('#resetButton');
  const downloadButton = document.querySelector<HTMLButtonElement>('#downloadButton');
  const beforeContext = beforeCanvas?.getContext('2d', { willReadFrequently: true });
  const afterContext = afterCanvas?.getContext('2d', { willReadFrequently: true });

  let originalImageData: ImageData | null = null;
  let processedImageData: ImageData | null = null;
  let sourceName = 'removecolor-image';
  let pendingFrame = 0;
  let pendingTimer = 0;

  function updatePreviewCanvasSize(): void {
    if (!beforeSurface || !afterSurface || !beforeCanvas || !afterCanvas || !originalImageData) {
      return;
    }

    const beforeBounds = beforeSurface.getBoundingClientRect();
    const afterBounds = afterSurface.getBoundingClientRect();
    const beforeSize = getContainedPreviewSize(
      { width: originalImageData.width, height: originalImageData.height },
      { width: beforeBounds.width, height: beforeBounds.height }
    );
    const afterSize = getContainedPreviewSize(
      { width: originalImageData.width, height: originalImageData.height },
      { width: afterBounds.width, height: afterBounds.height }
    );

    if (beforeSize.width === 0 || beforeSize.height === 0 || afterSize.width === 0 || afterSize.height === 0) {
      return;
    }

    beforeCanvas.style.width = `${beforeSize.width}px`;
    beforeCanvas.style.height = `${beforeSize.height}px`;
    afterCanvas.style.width = `${afterSize.width}px`;
    afterCanvas.style.height = `${afterSize.height}px`;
  }

  function drawOriginalImage(): void {
    if (!originalImageData || !beforeContext || !beforeCanvas) {
      return;
    }

    beforeContext.clearRect(0, 0, beforeCanvas.width, beforeCanvas.height);
    beforeContext.putImageData(originalImageData, 0, 0);
  }

  function setStatus(message: string): void {
    if (statusText) {
      statusText.textContent = message;
    }
  }

  function setActiveState(active: boolean): void {
    workspace?.setAttribute('data-active', String(active));
    if (beforeEmpty) {
      beforeEmpty.hidden = active;
    }
    if (resetButton) {
      resetButton.disabled = !active;
    }
    if (downloadButton) {
      downloadButton.disabled = !active;
    }
  }

  function syncRangeOutputs(): void {
    if (toleranceOutput && toleranceInput) {
      toleranceOutput.value = toleranceInput.value;
    }
    if (softnessOutput && softnessInput) {
      softnessOutput.value = softnessInput.value;
    }
    if (haloOutput && haloInput) {
      haloOutput.value = haloInput.value;
    }
  }

  function scheduleProcess(): void {
    syncRangeOutputs();

    if (!originalImageData || !afterContext || !afterCanvas) {
      return;
    }

    window.cancelAnimationFrame(pendingFrame);
    window.clearTimeout(pendingTimer);
    pendingFrame = window.requestAnimationFrame(() => {
      pendingFrame = 0;
      window.clearTimeout(pendingTimer);
      processImage();
    });
    pendingTimer = window.setTimeout(() => {
      if (pendingFrame !== 0) {
        window.cancelAnimationFrame(pendingFrame);
        pendingFrame = 0;
        processImage();
      }
    }, 80);
  }

  function applyPreset(button: HTMLButtonElement): void {
    if (!toleranceInput || !softnessInput || !haloInput) {
      return;
    }

    toleranceInput.value = button.dataset.tolerance ?? toleranceInput.value;
    softnessInput.value = button.dataset.softness ?? softnessInput.value;
    haloInput.value = button.dataset.halo ?? haloInput.value;

    presetButtons.forEach((item) => {
      item.setAttribute('aria-pressed', String(item === button));
    });
    scheduleProcess();
  }

  function markPresetAsCustom(): void {
    presetButtons.forEach((item) => {
      item.setAttribute('aria-pressed', 'false');
    });
  }

  function processImage(): void {
    if (!originalImageData || !afterContext || !targetHex || !toleranceInput || !softnessInput || !haloInput) {
      return;
    }

    try {
      const nextData = removeColorFromPixels(
        originalImageData.data,
        originalImageData.width,
        originalImageData.height,
        {
          target: parseHexColor(targetHex.value),
          tolerance: Number(toleranceInput.value),
          edgeSoftness: Number(softnessInput.value),
          haloCleanup: Number(haloInput.value)
        }
      );
      processedImageData = afterContext.createImageData(originalImageData.width, originalImageData.height);
      processedImageData.data.set(nextData);
      afterContext.clearRect(0, 0, afterCanvas?.width ?? 0, afterCanvas?.height ?? 0);
      afterContext.putImageData(processedImageData, 0, 0);
    setStatus('Preview updated. Click on a color in the input image.');
    } catch (error) {
      setStatus(error instanceof Error ? error.message : 'Unable to process this image.');
    }
  }

  async function loadImageFromSource(source: string, name: string): Promise<void> {
    if (!beforeContext || !afterContext || !beforeCanvas || !afterCanvas) {
      setStatus('Canvas is not available in this browser.');
      return;
    }

    const image = new Image();
    image.decoding = 'async';
    image.src = source;

    try {
      await image.decode();
    } catch {
      setStatus('Unable to read this image file.');
      return;
    }

    sourceName = name.replace(/\.[^.]+$/, '') || 'removecolor-image';
    beforeCanvas.width = image.naturalWidth;
    beforeCanvas.height = image.naturalHeight;
    afterCanvas.width = image.naturalWidth;
    afterCanvas.height = image.naturalHeight;
    beforeContext.clearRect(0, 0, beforeCanvas.width, beforeCanvas.height);
    beforeContext.drawImage(image, 0, 0);
    originalImageData = beforeContext.getImageData(0, 0, beforeCanvas.width, beforeCanvas.height);
    processedImageData = originalImageData;
    drawOriginalImage();
    setActiveState(true);
    updatePreviewCanvasSize();
    scheduleProcess();
  }

  function loadFile(file: File): void {
    if (!file.type.match(/^image\/(png|jpeg|webp)$/)) {
      setStatus('Use a PNG, JPG, JPEG, or WebP image.');
      return;
    }

    const url = URL.createObjectURL(file);
    loadImageFromSource(url, file.name).finally(() => URL.revokeObjectURL(url));
  }

  function sampleColorFromCanvas(event: MouseEvent): void {
    if (!originalImageData || !beforeCanvas || !targetHex || !targetColor) {
      return;
    }

    const rect = beforeCanvas.getBoundingClientRect();
    const x = Math.floor(((event.clientX - rect.left) / rect.width) * beforeCanvas.width);
    const y = Math.floor(((event.clientY - rect.top) / rect.height) * beforeCanvas.height);

    if (x < 0 || y < 0 || x >= beforeCanvas.width || y >= beforeCanvas.height) {
      return;
    }

    const index = (y * beforeCanvas.width + x) * 4;
    const color = {
      r: originalImageData.data[index],
      g: originalImageData.data[index + 1],
      b: originalImageData.data[index + 2]
    };
    const hex = rgbToHex(color);
    targetHex.value = hex;
    targetColor.value = hex;
    scheduleProcess();
  }

  function resetImage(): void {
    if (!originalImageData || !afterContext) {
      return;
    }

    processedImageData = originalImageData;
    drawOriginalImage();
    afterContext.putImageData(originalImageData, 0, 0);
    setStatus('Reset to the original image.');
  }

  function downloadPng(): void {
    if (!processedImageData) {
      return;
    }

    const exportCanvas = document.createElement('canvas');
    const exportContext = exportCanvas.getContext('2d');

    if (!exportContext) {
      setStatus('Unable to export this image.');
      return;
    }

    exportCanvas.width = processedImageData.width;
    exportCanvas.height = processedImageData.height;
    exportContext.putImageData(processedImageData, 0, 0);
    exportCanvas.toBlob((blob) => {
      if (!blob) {
        setStatus('Unable to export this image.');
        return;
      }

      const url = URL.createObjectURL(blob);
      const link = document.createElement('a');
      link.href = url;
      link.download = `${sourceName}-transparent.png`;
      link.click();
      URL.revokeObjectURL(url);
    }, 'image/png');
  }

  fileInput?.addEventListener('change', () => {
    const file = fileInput.files?.[0];

    if (file) {
      loadFile(file);
    }
  });

  beforeSurface?.addEventListener('dragover', (event) => {
    event.preventDefault();
    beforeSurface.setAttribute('data-dragging', 'true');
  });

  beforeSurface?.addEventListener('dragleave', () => {
    beforeSurface.removeAttribute('data-dragging');
  });

  beforeSurface?.addEventListener('drop', (event) => {
    event.preventDefault();
    beforeSurface.removeAttribute('data-dragging');
    const file = event.dataTransfer?.files[0];

    if (file) {
      loadFile(file);
    }
  });

  window.addEventListener('paste', (event) => {
    const pastedFile = Array.from(event.clipboardData?.items ?? [])
      .find((item) => item.type.match(/^image\/(png|jpeg|webp)$/))
      ?.getAsFile();

    if (pastedFile) {
      loadFile(pastedFile);
    }
  });

  beforeCanvas?.addEventListener('click', sampleColorFromCanvas);

  targetColor?.addEventListener('input', () => {
    if (targetHex && targetColor) {
      targetHex.value = targetColor.value;
      scheduleProcess();
    }
  });

  targetHex?.addEventListener('input', () => {
    if (!targetHex || !targetColor) {
      return;
    }

    try {
      const normalized = rgbToHex(parseHexColor(targetHex.value));
      targetColor.value = normalized;
      scheduleProcess();
    } catch {
      setStatus('Enter a valid HEX color such as #ffffff.');
    }
  });

  presetButtons.forEach((button) => {
    button.addEventListener('click', () => applyPreset(button));
  });

  for (const input of [toleranceInput, softnessInput, haloInput]) {
    input?.addEventListener('input', () => {
      markPresetAsCustom();
      scheduleProcess();
    });
  }

  document.querySelectorAll<HTMLButtonElement>('[data-bg]').forEach((button) => {
    button.addEventListener('click', () => {
      document.querySelectorAll<HTMLButtonElement>('[data-bg]').forEach((item) => {
        item.setAttribute('aria-pressed', String(item === button));
      });
      compareStage?.classList.remove('compare-stage--checker', 'compare-stage--white', 'compare-stage--black');
      compareStage?.classList.add(`compare-stage--${button.dataset.bg}`);
      compareStage?.style.removeProperty('--custom-preview-bg');
    });
  });

  customBg?.addEventListener('input', () => {
    compareStage?.classList.remove('compare-stage--checker', 'compare-stage--white', 'compare-stage--black');
    compareStage?.style.setProperty('--custom-preview-bg', customBg.value);
    document.querySelectorAll<HTMLButtonElement>('[data-bg]').forEach((item) => {
      item.setAttribute('aria-pressed', 'false');
    });
  });

  resetButton?.addEventListener('click', resetImage);
  downloadButton?.addEventListener('click', downloadPng);

  window.addEventListener('removecolor:load-example', (event) => {
    const detail = (event as CustomEvent<ExampleLoadDetail>).detail;

    if (!detail?.source || !detail?.name) {
      return;
    }

    setStatus('Loading example image...');
    loadImageFromSource(detail.source, detail.name);
    beforeSurface?.scrollIntoView({ behavior: 'smooth', block: 'center' });
  });

  if (compareStage && 'ResizeObserver' in window) {
    const previewResizeObserver = new ResizeObserver(() => updatePreviewCanvasSize());
    previewResizeObserver.observe(compareStage);
  }

  window.addEventListener('resize', updatePreviewCanvasSize);
  syncRangeOutputs();
</script>
