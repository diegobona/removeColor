---
import { compactExampleScenarios } from '../data/exampleScenarios';

const exampleSets = [
  { key: 'primary', hidden: false },
  { key: 'loop-copy', hidden: true }
];
---

<section class="compact-examples" aria-label="Quick before and after examples">
  <div class="compact-examples__intro">
    <strong>See it before you upload</strong>
    <span>Selected colors become transparent PNG areas.</span>
  </div>
  <div class="compact-examples__viewport">
    <div class="compact-examples__track">
      {
        exampleSets.map((set) => (
          <div
            class="compact-examples__set"
            data-set={set.key}
            aria-hidden={set.hidden ? 'true' : undefined}
          >
            {compactExampleScenarios.map((scenario) => (
              <article class="compact-example" data-scenario={scenario.id}>
                <div class="compact-example__meta">
                  <strong>{scenario.title}</strong>
                  <button
                    class="compact-example__cta"
                    type="button"
                    data-example-trigger
                    data-example-src={scenario.media?.beforeSrc}
                    data-example-name={scenario.media?.beforeSrc?.split('/').pop()}
                  >
                    Try it
                  </button>
                </div>
                <div class="compact-example__pair">
                  <div
                    class="compact-example__image compact-example__image--solid"
                    style={`--mock-bg: ${scenario.before.background};`}
                    data-example-trigger
                    data-example-src={scenario.media?.beforeSrc}
                    data-example-name={scenario.media?.beforeSrc?.split('/').pop()}
                  >
                    {
                      scenario.media ? (
                        <img
                          src={scenario.media.beforeSrc}
                          alt={scenario.media.alt}
                          loading="lazy"
                          decoding="async"
                        />
                      ) : null
                    }
                  </div>
                  <div class="compact-example__arrow" aria-hidden="true">-&gt;</div>
                  <div class="compact-example__image compact-example__image--transparent">
                    {
                      scenario.media ? (
                        <img
                          src={scenario.media.expectedAfterSrc}
                          alt={`${scenario.media.alt} after color removal`}
                          loading="lazy"
                          decoding="async"
                        />
                      ) : null
                    }
                  </div>
                </div>
              </article>
            ))}
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  type ExampleLoadDetail = {
    source: string;
    name: string;
  };

  document.querySelectorAll<HTMLElement>('[data-example-trigger]').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const source = trigger.dataset.exampleSrc;
      const name = trigger.dataset.exampleName;

      if (!source || !name) {
        return;
      }

      window.dispatchEvent(
        new CustomEvent<ExampleLoadDetail>('removecolor:load-example', {
          detail: { source, name }
        })
      );
    });
  });
</script>
