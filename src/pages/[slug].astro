---
import ColorTool from '../components/ColorTool.astro';
import CompactExampleStrip from '../components/CompactExampleStrip.astro';
import ExampleGallery from '../components/ExampleGallery.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { seoPages } from '../data/seoPages';

export function getStaticPaths() {
  return seoPages.map((page) => ({
    params: { slug: page.slug },
    props: { page }
  }));
}

const { page } = Astro.props;
---

<SiteLayout
  title={page.title}
  description={page.description}
  canonicalPath={`/${page.slug}/`}
  faq={page.faqs}
>
  <main>
    <section class="hero section">
      <div class="section__inner hero__grid">
        <div class="hero__copy">
          <a class="brand-lockup brand-lockup--link" href="/" aria-label="RemoveColor home">
            <span class="brand-mark" aria-hidden="true">
              <span class="brand-mark__tile brand-mark__tile--blue"></span>
              <span class="brand-mark__tile brand-mark__tile--teal"></span>
              <span class="brand-mark__tile brand-mark__tile--clear"></span>
              <span class="brand-mark__cut"></span>
            </span>
            <span>RemoveColor</span>
          </a>
          <p class="eyebrow">Browser-based image color remover</p>
          <h1>{page.h1}</h1>
          <p class="hero__intro">{page.intro}</p>
          <div class="hero__proof" aria-label="Color removal workflow">
            <span><strong>1</strong> Pick color</span>
            <span><strong>2</strong> Clean edge</span>
            <span><strong>3</strong> Export transparent PNG</span>
          </div>
          <div class="hero__badges" aria-label="Key benefits">
            <span>Pick a color</span>
            <span>Clean edges</span>
            <span>Export PNG</span>
          </div>
        </div>
        <CompactExampleStrip />
        <ColorTool />
      </div>
    </section>

    <ExampleGallery />

    <section class="section">
      <div class="section__inner faq-list">
        <p class="eyebrow">FAQ</p>
        <h2>{page.h1} questions</h2>
        {page.faqs.map((item) => (
          <details>
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </section>
  </main>
</SiteLayout>
