---
import ColorTool from '../components/ColorTool.astro';
import CompactExampleStrip from '../components/CompactExampleStrip.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { homePage, seoPages } from '../data/seoPages';
---

<SiteLayout title={homePage.title} description={homePage.description} faq={homePage.faqs}>
  <main>
    <section class="hero section">
      <div class="section__inner hero__grid">
        <div class="hero__copy">
          <div class="brand-lockup" aria-label="RemoveColor">
            <span class="brand-mark" aria-hidden="true">
              <span class="brand-mark__tile brand-mark__tile--blue"></span>
              <span class="brand-mark__tile brand-mark__tile--teal"></span>
              <span class="brand-mark__tile brand-mark__tile--clear"></span>
              <span class="brand-mark__cut"></span>
            </span>
            <span>RemoveColor</span>
          </div>
          <p class="eyebrow">Free online color remover</p>
          <h1>{homePage.h1}</h1>
          <p class="hero__intro">{homePage.intro}</p>
          <div class="hero__proof" aria-label="Color removal workflow">
            <span><strong>1</strong> Pick color</span>
            <span><strong>2</strong> Clean edge</span>
            <span><strong>3</strong> Export transparent PNG</span>
          </div>
          <div class="hero__badges" aria-label="Key benefits">
            <span>Local processing</span>
            <span>Transparent PNG</span>
            <span>No signup</span>
          </div>
        </div>
        <CompactExampleStrip />
        <ColorTool />
      </div>
    </section>

    <section class="section">
      <div class="section__inner">
        <p class="eyebrow">More color tools</p>
        <h2>Focused pages for common color-removal tasks</h2>
        <div class="tool-link-grid">
          {seoPages.map((page) => (
            <a href={`/${page.slug}/`}>
              <strong>{page.h1}</strong>
              <span>{page.focus}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="section section--muted">
      <div class="section__inner faq-list">
        <p class="eyebrow">FAQ</p>
        <h2>Color remover questions</h2>
        {homePage.faqs.map((item) => (
          <details>
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </section>
  </main>
</SiteLayout>
